{
  "heat_template_version": "2021-04-16",
  "description": "the mesh overlay network stack",
  "resources": {
    "overlay_net": {
      "type": "OS::Neutron::Net",
      "properties": { "name": "private" }
    },
    "overlay_subnet": {
      "type": "OS::Neutron::Subnet",
      "properties": {
        "network": { "get_resource": "overlay_net" },
        "cidr": "10.0.0.0/24"
      }
    }
  },
  "outputs": {
    "network_id": { "value": { "get_resource": "overlay_net" } }
  }
}

[Desktop Entry]
Type=Application
Name=Construct
Comment=Construct desktop environment by Software Studio: MDE
# E12-3 "Construct" — the single egui shell. Built `--features drm` it OWNS the DRM/KMS
# seat directly (no compositor); launched from an existing session it runs as a
# windowed client (the run_drm → NoDrmMaster → run_client fallback in main.rs). This
# .desktop is the session-launch face; the seat-boot face is a systemd unit (E12-3).
Exec=mde-shell-egui
Icon=magic-mesh
Terminal=false
Categories=System;Utility;

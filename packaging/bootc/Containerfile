# E12-13 — the ONE immutable MCNF bootc/ostree image, every role (§5 delivery lock).
#
# One image for Lighthouse AND Workstation: role is a config flag
# (/var/lib/mde/role.toml, pinned by magic-setup / `mackesd found|join`), never a
# separate build. A Lighthouse runs this exact image with the desktop seat unit
# skipped (its ExecCondition) or masked (Option 1) — see README.md "Roles".
#
# Build (both lanes) via ./build-image.sh; context is the REPO ROOT:
#   podman build -f packaging/bootc/Containerfile .
#
# ── Writable-partition doctrine (what survives a `bootc upgrade`) ─────────────
# bootc/ostree gives three lanes; every stateful path the RPM + units use is
# pinned to a surviving one (grep-verified against packaging/systemd/* and the
# mackesd sources — each path annotated below):
#
#  /usr, /boot        IMMUTABLE image content — swapped atomically per upgrade.
#  /etc               3-way merged: image defaults update, LOCAL EDITS PERSIST.
#    /etc/mackesd                daemon config, etcd-endpoints, backup-passphrase.cred
#                                (mackesd.service EFF-15; post-install `install -d -m0700`)
#    /etc/nebula                 overlay identity/certs, materialized by mackesd (EFF-29)
#    /etc/etcd/etcd.env          written by setup-etcd.sh; etcd.service gates on it
#    /etc/systemd/system/…       etcd.service + syncthing.service (RPM installs them to
#                                /etc for admin precedence) + setup-written drop-ins
#                                (syncthing.service.d/10-home.conf, mackesd.service.d/*)
#    /etc/hosts                  mesh_dns <host>.mesh merges persist
#  /var               MACHINE-LOCAL: image /var only SEEDS the FIRST boot;
#                     upgrades NEVER touch it. All live state lands here:
#    /var/lib/mackesd            daemon state (unit ExecStartPre `install -d -m0700`,
#                                deliberately not StateDirectory= — LIGHTHOUSE-VARMOUNT)
#    /var/lib/mde/role.toml      THE role flag (+ the `branded` run-once stamp)
#    /var/lib/etcd               etcd data dir
#    /var/lib/mcnf-syncthing     Syncthing home (syncthing.service Environment=)
#    /var/home/<u>/Local         ~/Local VM running disks (mde-kvm running_disk_path,
#                                lock 18 — never mesh-synced); /home → var/home
#    /var/mnt/mesh-storage       the Syncthing-replicated workgroup dir; /mnt → var/mnt,
#                                so the tmpfiles.d line `d /mnt/mesh-storage` (RPM's
#                                magic-mesh.conf) creates it through the symlink and
#                                MDE_WORKGROUP_ROOT=/mnt/mesh-storage keeps resolving
#    /var/opt/mcnf               ⚠ the automation/backoffice plane (/opt → var/opt).
#                                RPM content under /opt is a FIRST-BOOT SEED ONLY on
#                                bootc — image upgrades do NOT refresh it. Acceptable:
#                                that plane converges control-VM-side (DAR-46); caveat
#                                documented in README.md.
#  /run/mde-bus       tmpfs, re-created every boot by tmpfiles (magic-mesh.conf).
#
# So: a `bootc upgrade` swaps /usr atomically and cannot touch ~/Local VM disks,
# /mnt/mesh-storage, /etc/mackesd or /etc/nebula — the E12-13 acceptance line.
# ──────────────────────────────────────────────────────────────────────────────

# Fedora 42 matches the fleet's RPM channel (the gh-pages repo serves
# fedora-$releasever; the mesh-service container image is FROM fedora:42 too).
# Override with --build-arg BOOTC_BASE=… for an F43+ rebase.
ARG BOOTC_BASE=quay.io/fedora/fedora-bootc:42
FROM ${BOOTC_BASE}

# Two RPM lanes (build-image.sh drives this):
#   repo  (default) — install magic-mesh from the GitHub-hosted dnf channel
#                     (PKG-8; the .repo file below). Needs network at build.
#   local           — install a locally-built magic-mesh-*.rpm staged into
#                     packaging/bootc/rpms/ by `build-image.sh --rpm <path>`.
ARG MCNF_RPM_LANE=repo

# The staging dir always COPYies (it carries a .gitkeep, so the repo lane works
# with an empty dir); the channel .repo ships regardless — the RPM installs the
# same file, and it keeps `bootc switch` rebases + debugging honest.
COPY packaging/bootc/rpms/ /tmp/mcnf-rpms/
COPY packaging/repo/magic-mesh.repo /etc/yum.repos.d/magic-mesh.repo

# The magic-mesh RPM carries every binary + unit + asset (PKG-1: ONE monolithic
# RPM; its post-install scriptlet runs here and its `systemctl enable` calls are
# offline-safe symlink creation). Weak deps stay ON — this is the full
# Workstation image; a Lighthouse runs the same bits with the seat masked (§5).
# podman is half the §5 VDI substrate (mackesd's kvm probe checks
# podman.socket) — the fedora-bootc base already ships it, the explicit install
# is a no-op guard against future base slimming; nebula arrives as the RPM's
# hard Require. cloud-hypervisor is baked separately below (NOT in Fedora 42 —
# proven live: `No match for argument: cloud-hypervisor`, farm build 2026-07-01).
RUN set -eux; \
    if [ "${MCNF_RPM_LANE}" = "local" ]; then \
        ls /tmp/mcnf-rpms/magic-mesh-*.rpm >/dev/null 2>&1 || { \
            echo "FATAL: MCNF_RPM_LANE=local but no magic-mesh-*.rpm staged in packaging/bootc/rpms/"; \
            echo "       stage one via: packaging/bootc/build-image.sh --rpm <path-to-rpm>"; \
            exit 1; }; \
        dnf -y install /tmp/mcnf-rpms/magic-mesh-*.rpm; \
    else \
        dnf -y install magic-mesh; \
    fi; \
    dnf -y install podman; \
    dnf clean all; \
    rm -rf /tmp/mcnf-rpms

# E12-19 (Quasar host controls) — the seat services the compositor-less shell
# owns in-process (audio / Bluetooth / power / DDC brightness). The RPM's
# `requires` pull these on a dnf install, but the bootc image is composed
# offline, so install them explicitly here too: PipeWire + WirePlumber (the DAW
# mixer's graph, lock 2) with the pipewire-alsa shim for the existing ALSA
# users, BlueZ (pairing + BT hotkey), UPower (multi-battery telemetry), and
# ddcutil + i2c-tools (external-monitor DDC/CI brightness, lock 13). The seat
# self-gates on the Workstation role, so a Lighthouse image carries them idle.
RUN set -eux; \
    dnf -y install \
        pipewire wireplumber pipewire-alsa \
        bluez upower \
        ddcutil i2c-tools; \
    dnf clean all

# E12-23 (Storage plane filesystem depth, workbench-storage-plane.md lock 6) — the
# fs-tooling matrix the Storage worker's UDisks2 executor + fs_tools verb layer
# shells to format/label/resize/encrypt on a shipped node. The RPM's `requires`
# pull these on a dnf install, but the bootc image is composed offline, so install
# them explicitly here too (mirroring the seat block above): udisks2 (the D-Bus
# block backend), e2fsprogs/xfsprogs/btrfs-progs/exfatprogs/dosfstools/ntfs-3g+
# ntfsprogs (the per-fs mkfs/label/check/resize tools), cryptsetup (LUKS), parted
# (the partition-geometry step of the shrink/move choreography), and qemu-img (the
# E12-22 virtual-disk lifecycle). A fresh bootc image thus carries every tool so no
# locked format degrades to an honest "unavailable" on a shipped node.
RUN set -eux; \
    dnf -y install \
        udisks2 \
        e2fsprogs xfsprogs btrfs-progs exfatprogs dosfstools \
        ntfs-3g ntfsprogs \
        cryptsetup parted \
        qemu-img; \
    dnf clean all

# SURFACE-1 (Microsoft Surface tablet/laptop enablement, docs/design/
# surface-tablet-enablement.md locks 1 + 10) — the conditional **linux-surface**
# layer. ONE Workstation image serves every node (lock 10, like the seat/storage
# blocks above); this set is INERT on non-Surface hardware — iptsd only activates
# on a real /dev/ipts digitizer, the Surface kernel modules only bind Surface
# Aggregator (SAM) hardware, surface-control no-ops without a SAM device — so
# baking it universally makes a Surface boot tablet-ready with NO day-2 kernel
# surgery (lock 1: enablement rides the image; update = image swap) while costing
# an idle non-Surface box nothing. Source = the canonical linux-surface project
# (github.com/linux-surface); its Fedora channel is pkg.surfacelinux.com, packages
# signed by the project key (surface.asc on the linux-surface GitHub repo).
#   · kernel-surface     — the patched kernel + Surface modules (IPTS touch/pen,
#                          SAM battery/thermal/perf, Type Cover, sensors/accel,
#                          WiFi/BT quirks, S0ix suspend). A mainline superset — its
#                          extra modules stay dormant on non-Surface silicon.
#   · iptsd              — the Intel Precise Touch & Stylus userspace daemon; a
#                          systemd socket that self-activates ONLY on a real IPTS
#                          digitizer, so it idles on non-Surface hardware.
#   · libwacom-surface   — the Surface pen/tablet device-DB overlay for libwacom.
#   · surface-control    — the surface-control CLI (SAM perf profile / DTX latch /
#                          dGPU) the SURFACE-3 surface_enable worker drives.
#   · surface-secureboot — stages the linux-surface MOK signing cert for the
#                          SURFACE-3 guided `mokutil --import` Secure-Boot flow
#                          (the modules are signed by this key).
#   · fwupd              — the LVFS firmware client the SURFACE-5 firmware panel
#                          drives (UEFI / touch-controller / SAM); a standard
#                          Fedora package, universal on every role.
# The repo pins skip_if_unavailable so a transient mirror outage degrades to "no
# surface packages" rather than failing the whole image build; gpgcheck stays ON
# (packages are project-signed; repo_gpgcheck off matches upstream's repodata).
# $releasever expands to the bootc base's Fedora release, so an F43 rebase tracks
# the matching linux-surface channel. --allowerasing lets kernel-surface REPLACE
# the base kernel (the intended single-kernel bootc image; the surface kernel is
# the mainline superset described above). Network egress to pkg.surfacelinux.com +
# raw.githubusercontent.com is needed here (gated like the cloud-hypervisor fetch
# below); airgapped builders point at a LAN mirror.
RUN set -eux; \
    rpm --import https://raw.githubusercontent.com/linux-surface/linux-surface/master/pkg/keys/surface.asc || { \
        echo "GATED[SURFACE-1/key]: cannot fetch the linux-surface signing key"; \
        echo "  the builder needs egress to raw.githubusercontent.com here (or a LAN mirror)"; \
        exit 1; }; \
    printf '%s\n' \
        '[linux-surface]' \
        'name=linux-surface' \
        'baseurl=https://pkg.surfacelinux.com/fedora/f$releasever/' \
        'enabled=1' \
        'gpgcheck=1' \
        'repo_gpgcheck=0' \
        'skip_if_unavailable=1' \
        'gpgkey=https://raw.githubusercontent.com/linux-surface/linux-surface/master/pkg/keys/surface.asc' \
        > /etc/yum.repos.d/linux-surface.repo; \
    dnf -y --allowerasing install \
        kernel-surface iptsd libwacom-surface \
        surface-control surface-secureboot \
        fwupd; \
    dnf clean all

# The other half of the VDI substrate: **cloud-hypervisor, baked in** (§5 /
# E12-13). Fedora 42 does not package it, so pin the upstream static-musl
# release binary and verify its sha256 — the pin makes every rebuild
# tamper-evident; bump CH_VERSION + CH_SHA256 together. Installed at
# /usr/bin/cloud-hypervisor, the FIRST path mackesd's local_virt_ready() probe
# checks (spawn_lighthouse.rs); mde-kvm drives the running VMM over its
# api-socket, so the one binary is the whole requirement (ch-remote is a debug
# nicety, deliberately not baked). CH_URL is overridable for a LAN mirror on
# an airgapped builder; the sha256 gate still applies to the mirror's copy.
ARG CH_VERSION=v52.0
ARG CH_SHA256=829af01ff075bb96c4f183905134c453a88d68cbabdc6b87df21098842581ee9
ARG CH_URL=https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/${CH_VERSION}/cloud-hypervisor-static
RUN set -eux; \
    command -v curl >/dev/null 2>&1 || dnf -y install curl; \
    curl -sfL --retry 3 -o /tmp/cloud-hypervisor "${CH_URL}" || { \
        echo "GATED[E12-13/ch-release]: cannot fetch cloud-hypervisor ${CH_VERSION} from ${CH_URL}"; \
        echo "  the builder needs GitHub egress here — or point CH_URL at a LAN mirror"; \
        echo "  (--build-arg CH_URL=…); the sha256 pin below still guards the mirror copy."; \
        exit 1; }; \
    echo "${CH_SHA256}  /tmp/cloud-hypervisor" | sha256sum -c -; \
    install -m 0755 /tmp/cloud-hypervisor /usr/bin/cloud-hypervisor; \
    rm -f /tmp/cloud-hypervisor; \
    /usr/bin/cloud-hypervisor --version

# The DRM-seat unit (bootc lane only — the dnf/RPM lane keeps the .desktop
# launcher) + its preset. Boot-to-seat: quasar-vdi-desktop.md lock 34.
COPY packaging/bootc/units/mde-shell-egui.service /usr/lib/systemd/system/mde-shell-egui.service
COPY packaging/bootc/system-preset/45-mcnf-quasar.preset /usr/lib/systemd/system-preset/45-mcnf-quasar.preset

# Workstation-role wiring. The RPM post-install already enabled the all-roles
# set (mackesd, nebula, mesh-health.timer, mesh-status.timer, the first-boot
# setup oneshots, magic-setup, magic-mesh-brand + the mde-musicd user unit);
# this adds the VDI seat + the podman API socket (the preset above is the
# declared policy, the enable materializes it in the image /etc now) and boots
# to graphical. NOTHING is masked by default (§5): the seat unit self-gates on
# the role flag, so this one image serves every role unmodified.
RUN systemctl enable mde-shell-egui.service podman.socket && \
    systemctl set-default graphical.target

# Surface bootc's own image lint in the build log (non-fatal: it flags the
# known /var seeding — e.g. the /opt/mcnf automation plane — which is
# documented doctrine above, not an accident).
RUN bootc container lint || echo "WARN: bootc container lint reported findings (documented /var seeding; see doctrine block above)"

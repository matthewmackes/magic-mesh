[Desktop Entry]
Type=Application
Name=MCNF Live Wallpaper
Comment=Live mesh-overview map as the Cosmic desktop background (PD-10); Workstation-rank gated — Servers/Lighthouses are headless
Exec=sh -c "mackesd role-gate --min-rank 2 && exec mde-mesh-wallpaper"
Icon=magic-mesh
Terminal=false
NoDisplay=true
X-GNOME-Autostart-enabled=true

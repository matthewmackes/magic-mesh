# BROWSER-DD-11 optional offline STT model for Browser voice commands/dictation.
#
# Magic Mesh does not guess or silently download an STT model. This manifest is
# the first-run, sha256-pinned provisioning contract for an approved offline STT
# model. Populate the URL/SHA fields from an approved source or pre-place the
# named assets in the cache before running install-browser-stt-model.
STT_MODEL_ID="browser-voice-command"
STT_MODEL_VERSION=""
STT_MODEL_ASSET=""
STT_MODEL_URL=""
STT_MODEL_SHA256=""
STT_MODEL_SIZE_BYTES=""
STT_MODEL_CONFIG_ASSET=""
STT_MODEL_CONFIG_URL=""
STT_MODEL_CONFIG_SHA256=""
STT_MODEL_CONFIG_SIZE_BYTES=""
STT_MODEL_INSTALL_PARENT="/usr/share/magic-mesh/stt/models"
STT_MODEL_ACTIVE_MODEL="/usr/share/magic-mesh/stt/browser-voice-command.model"
STT_MODEL_RUNTIME_NOTE="Set MDE_BROWSER_STT_TRANSCRIBE_COMMAND to the approved offline runtime command; it receives audio WAV, request JSON, and model path as argv 1, 2, and 3."
STT_MODEL_LICENSE_NOTE="STT model must come from an approved, sha256-pinned offline model source before Browser voice commands can transcribe audio."

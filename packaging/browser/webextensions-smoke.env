# MCNF Browser CEF WebExtensions runtime smoke registry.
#
# Use this registry with a live CEF runtime to prove Chromium's extension host
# executed a content script and completed an autofill-shaped form mutation:
#
#   MDE_CEF_EXTENSION_REGISTRY=/usr/share/magic-mesh/browser/webextensions-smoke.env
#   MDE_CEF_EXTENSION_POWER_MODE=true
#   MDE_CEF_WEBEXTENSIONS_LAB=true
#   MDE_CEF_BROWSER_PROBE=1
#   MDE_CEF_TEXT_PROBE_EXPECT=mde-cef-extension-autofill-ok
#
# The fixture is intentionally not the production allowlist. It loads one
# packaged unpacked extension that appends a visible marker to every page and
# fills simple login forms so `MDE_CEF_TEXT_PROBE_EXPECT` can observe both the
# extension host and an autofill-shaped DOM mutation through the page-text beacon.

[extension.aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa]
name = "MCNF CEF Extension Smoke"
version = "1.0.0"
path = "smoke-extension"
permissions = <all_urls>
power_sideload = true

# BROWSER-DD-12 optional offline/mesh translation model for Browser.
#
# Magic Mesh does not guess or silently download a translation model. This
# manifest is the first-run, sha256-pinned provisioning contract for an approved
# offline/mesh translation model. Populate the URL/SHA fields from an approved
# source or pre-place the named assets in the cache before running
# install-browser-translate-model.
TRANSLATE_MODEL_ID="browser-translate"
TRANSLATE_MODEL_VERSION=""
TRANSLATE_MODEL_ASSET=""
TRANSLATE_MODEL_URL=""
TRANSLATE_MODEL_SHA256=""
TRANSLATE_MODEL_SIZE_BYTES=""
TRANSLATE_MODEL_CONFIG_ASSET=""
TRANSLATE_MODEL_CONFIG_URL=""
TRANSLATE_MODEL_CONFIG_SHA256=""
TRANSLATE_MODEL_CONFIG_SIZE_BYTES=""
TRANSLATE_MODEL_INSTALL_PARENT="/usr/share/magic-mesh/translate/models"
TRANSLATE_MODEL_ACTIVE_MODEL="/usr/share/magic-mesh/translate/browser-translate.model"
TRANSLATE_MODEL_RUNTIME_NOTE="Set MDE_BROWSER_TRANSLATE_ENGINE_COMMAND to the approved offline/mesh translation runtime command; it receives request JSON and model path as argv 1 and 2."
TRANSLATE_MODEL_LICENSE_NOTE="Translation model/runtime must come from an approved, sha256-pinned offline or mesh-local source before Browser translation can produce text."

# BROWSER-DD-4 optional Widevine CDM runtime for the Linux x86_64 CEF engine.
#
# Magic Mesh must not redistribute the Widevine CDM. This manifest is the
# first-run, Firefox-style fetch contract: an operator or build/release pipeline
# provides a licensed, sha256-pinned CDM archive URL before enabling DRM
# streaming. Without those fields, the browser remains fully functional for
# non-DRM browsing and the installer exits with a clean configuration gate.
WIDEVINE_VERSION=""
WIDEVINE_PLATFORM="linux64"
WIDEVINE_ASSET=""
WIDEVINE_URL=""
WIDEVINE_SHA256=""
WIDEVINE_SIZE_BYTES=""
WIDEVINE_INSTALL_PARENT="/opt/mde/widevine-cdms"
WIDEVINE_ACTIVE_LINK="/opt/mde/widevine"
WIDEVINE_LICENSE_NOTE="Widevine CDM is fetched from an operator-provided licensed source and is not redistributed by Magic Mesh."

# BROWSER-DD-11 optional Piper voice model for Browser read-aloud.
#
# Magic Mesh does not guess or silently download a voice model. This manifest is
# the first-run, sha256-pinned provisioning contract for an approved offline
# Piper model. Populate the URL/SHA fields from an approved source or pre-place
# the named assets in the cache before running install-browser-tts-voice.
TTS_VOICE_ID="browser-read-aloud"
TTS_VOICE_VERSION=""
TTS_VOICE_MODEL_ASSET=""
TTS_VOICE_MODEL_URL=""
TTS_VOICE_MODEL_SHA256=""
TTS_VOICE_MODEL_SIZE_BYTES=""
TTS_VOICE_CONFIG_ASSET=""
TTS_VOICE_CONFIG_URL=""
TTS_VOICE_CONFIG_SHA256=""
TTS_VOICE_CONFIG_SIZE_BYTES=""
TTS_VOICE_INSTALL_PARENT="/usr/share/magic-mesh/tts/voices"
TTS_VOICE_ACTIVE_MODEL="/usr/share/magic-mesh/tts/browser-read-aloud.onnx"
TTS_VOICE_LICENSE_NOTE="Piper voice model must come from an approved, sha256-pinned offline model source before Browser read-aloud can synthesize audio."

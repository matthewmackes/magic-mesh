{
  "manifest_version": 2,
  "name": "MCNF CEF Extension Smoke",
  "version": "1.0.0",
  "description": "Runtime smoke fixture for the MCNF CEF WebExtensions gate.",
  "permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "smoke.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

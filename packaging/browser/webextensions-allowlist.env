# MCNF Browser curated WebExtensions registry template.
#
# Copy this file into the mesh-hosted registry path:
#   /mnt/mesh-storage/browser/extensions/allowlist.env
#
# V1 does not load WebExtensions in production. Native ad/tracker blocking,
# passkeys, reader mode, userscripts, and site styles are the supported browser
# path. This template records the future/lab registry shape only: each listed
# extension must be an unpacked, operator-vetted directory below the registry
# directory with a valid Chrome manifest.json before `mde-web-cef` reports
# CEF_EXTENSIONS_READY, and even then production launch reports
# CEF_EXTENSIONS_SKIPPED_V1 unless MDE_CEF_WEBEXTENSIONS_LAB is set.

[extension.hdokiejnpimakedhajhdlcegeplioahd]
name = "LastPass"
version = "operator-pinned"
path = "lastpass"
permissions = storage,tabs,webRequest,<all_urls>
power_sideload = true

[extension.cjpalhdlnbpafiamejdnhcphjbkeiagm]
name = "uBlock Origin"
version = "operator-pinned"
path = "ublock-origin"
permissions = storage,tabs,webRequest,webRequestBlocking,<all_urls>
power_sideload = true

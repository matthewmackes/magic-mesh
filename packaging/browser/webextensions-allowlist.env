# MCNF Browser curated WebExtensions registry template.
#
# Copy this file into the mesh-hosted registry path:
#   /mnt/mesh-storage/browser/extensions/allowlist.env
#
# Each listed extension must be an unpacked, operator-vetted directory below the
# registry directory with a valid Chrome manifest.json before `mde-web-cef`
# reports CEF_EXTENSIONS_READY. The CEF runtime still needs live autofill smoke
# proof before BROWSER-DD-5 closes; this template records the vetted ids and
# expected shape only.

[extension.hdokiejnpimakedhajhdlcegeplioahd]
name = "LastPass"
version = "operator-pinned"
path = "lastpass"
permissions = storage,tabs,webRequest,<all_urls>
power_sideload = true

[extension.cjpalhdlnbpafiamejdnhcphjbkeiagm]
name = "uBlock Origin"
version = "operator-pinned"
path = "ublock-origin"
permissions = storage,tabs,webRequest,webRequestBlocking,<all_urls>
power_sideload = true

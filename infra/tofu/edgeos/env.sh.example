# cp to env.sh (gitignored); source before tofu in this root:
#   source ./env.sh && tofu plan
#
# DAR-5/DAR-10: the EdgeOS SSH password comes from the MESH SECRET STORE
# (/mcnf/secret/edgeos-cred, age-encrypted in etcd) — NO host-local /root/.mcnf-ubnt-cred
# plaintext, NO literal in any tracked file. The shared tofu-env.sh library unseals it
# with THIS node's own age key (DAR-3 secret-zero), writes it to a TMPFS 0600 file
# that the EdgeOS scripts read via `sshpass -f`, and SHREDS that file on exit — so the
# password never lands in the repo, a dotfile, tofu state, or a log.
#
# Fold the legacy file in once with:
#   automation/secrets/migrate-cred-files.sh --apply --only edgeos-cred
# (or seal a fresh one:  printf %s '<password>' | mcnf-secret.sh put edgeos-cred)
. "$(git rev-parse --show-toplevel)/automation/lib/tofu-env.sh"
tofu_env_load edgeos

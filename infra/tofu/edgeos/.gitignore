# Local tofu state holds live lease data (MACs/hostnames) + the null_resource
# id — never commit it; the device config itself is the durable record.
.terraform/
terraform.tfstate
terraform.tfstate.*
tfplan
crash.log
# DAR-8: the per-mesh backend address is generated (gen-backend-config.sh), never committed.
*.backend.hcl
# WL-RUN-006: real per-appliance instances carry per-site reservations + backend
# addresses — never commit them; only the *.example templates + README are tracked.
appliances/*.tfvars
appliances/*.backend.hcl
!appliances/*.example

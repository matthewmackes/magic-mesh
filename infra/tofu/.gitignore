# State can contain sensitive values + is environment-specific.
# (.terraform.lock.hcl IS committed — it pins provider versions for reproducibility.)
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# Never commit the real token/env.
env.sh
*.auto.tfvars
override.tf
override.tf.json
# FARM-AUTOSCALE per-tick runtime state + lifecycle log (host/time-specific;
# the autoscaler regenerates them — see install-helpers/farm-autoscale.sh).
farm-autoscale.state
farm-autoscale.log

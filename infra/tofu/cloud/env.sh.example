# cp to env.sh (gitignored); source before tofu in this root:
#   source ./env.sh && tofu plan
#
# The cloud root needs NO provider token: libvirt is reached over the local
# socket (qemu:///system) or the mesh SSH key (qemu+ssh://…). The ONE secret it
# consumes — the Nebula join/enrollment token baked into each VM's cloud-init —
# is unsealed at APPLY time by the mde-seal external data source (secrets.tf),
# which shells `mcnf-secret.sh get <join_token_secret>`. That helper resolves the
# etcd store from /etc/mackesd/etcd-endpoints on a deployed node; for a dev run
# off-node, point it at the store explicitly:
#
#   export MCNF_ETCD="http://<control-overlay-ip>:2379"
#
# and make sure this node's age key can decrypt the sealed token (mcnf-secret.sh
# reseal-to <this-node-recipient>, run by an operator/leader).
#
# Seal a fresh join token first (operator):
#   printf %s '<nebula-join-token>' | mcnf-secret.sh put nebula-join-token

# cp to env.sh (gitignored); source before tofu. Both secrets come from the mesh
# secret store (age-encrypted in etcd) — NO host-local plaintext, NO literal in any
# tracked file. Any node holding (or re-sealed into) the mesh age key resolves them.
SECRET="$(git rev-parse --show-toplevel)/automation/secrets/mcnf-secret.sh"

# XAPI password for the founding dom0 (TF_VAR_xapi_password → provider).
export TF_VAR_xapi_password="$("$SECRET" get xapi-password)"

# Enroll token for `mackesd join <token> --role server` (TF_VAR_join_token → cloud-init).
# The control VM consumes it once at first boot; it is never persisted as a literal.
export TF_VAR_join_token="$("$SECRET" get join-token)"

# Per-mesh init (NO hardcoded LAN address): the state-backend address is supplied
# via -backend-config, generated by gen-backend-config.sh (DAR-8):
#   tofu init -backend-config=control-vm.backend.hcl

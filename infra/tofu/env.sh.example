# DEPRECATED (DAR XO-deprecation): this root is the dead Xen Orchestra path — the
# farm is XAPI-managed via infra/tofu/xen-xapi/. Do NOT apply this root. The dead
# LAN websocket literal is removed; set XOA_URL yourself only if you ever revive XO.
# Source this (cp to env.sh, which is gitignored) before running tofu:
#   source ./env.sh && tofu plan
# DAR-5: the XO token now comes from the MESH SECRET STORE (age-encrypted in etcd) —
# NO host-local /root/.mcnf-xo-token plaintext, NO literal in any tracked file. Fold
# the legacy file in with automation/secrets/migrate-cred-files.sh, then this resolves
# it via the VM's own age key (DAR-3 secret-zero). The minter (xo-mint-token.sh) can
# still pipe a fresh token straight into the store: ... | mcnf-secret.sh put xo-token.
export XOA_URL="${XOA_URL:?set XOA_URL explicitly — the dead .192 default was removed (XO deprecated)}"
export XOA_INSECURE=true
export XOA_TOKEN="$("$(git rev-parse --show-toplevel)/automation/secrets/mcnf-secret.sh" get xo-token)"

# Source this (cp to env.sh, which is gitignored) before running tofu:
#   source ./env.sh && tofu plan
# The token is a SECRET kept off-repo at /root/.mcnf-xo-token (0600), minted with
# install-helpers/xo-mint-token.sh. Only the token is sensitive — url/insecure
# are also set as tofu vars in variables.tf (env here just keeps them together).
export XOA_URL="ws://172.20.145.192:8080"
export XOA_INSECURE=true
export XOA_TOKEN="$(cat /root/.mcnf-xo-token)"

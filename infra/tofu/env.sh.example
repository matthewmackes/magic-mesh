# DEPRECATED (DAR XO-deprecation): this root is the dead Xen Orchestra path — the
# farm is XAPI-managed via infra/tofu/xen-xapi/. Do NOT apply this root. The dead
# LAN websocket literal is removed; set XOA_URL yourself only if you ever revive XO.
# Source this (cp to env.sh, which is gitignored) before running tofu:
#   source ./env.sh && tofu plan
# The token is a SECRET kept off-repo at /root/.mcnf-xo-token (0600), minted with
# install-helpers/xo-mint-token.sh.
export XOA_URL="${XOA_URL:?set XOA_URL explicitly — the dead .192 default was removed (XO deprecated)}"
export XOA_INSECURE=true
export XOA_TOKEN="$(cat /root/.mcnf-xo-token)"

# Source this (cp to env.sh, which is gitignored) before running tofu here:
#   source ./env.sh && tofu plan
# The API token is a SECRET kept off-repo at /root/.mcnf-do-token (0600),
# extracted from the doctl `mackes` context. Nothing else here is sensitive.
export DIGITALOCEAN_TOKEN="$(cat /root/.mcnf-do-token)"

# Source this (cp to env.sh, which is gitignored) before running tofu here:
#   source ./env.sh && tofu plan
# The DO token comes from the mesh secret store (DATACENTER-3: age-encrypted in
# etcd) — no host-local plaintext; any node holding the mesh age key resolves it.
export DIGITALOCEAN_TOKEN="$("$(git rev-parse --show-toplevel)/automation/secrets/mcnf-secret.sh" get do-token)"

# cp to env.sh (gitignored); source before tofu. The XAPI password comes from the
# mesh secret store (DATACENTER-3: age-encrypted in etcd) — no host-local plaintext;
# any node holding the mesh age key resolves it.
export TF_VAR_xapi_password="$("$(git rev-parse --show-toplevel)/automation/secrets/mcnf-secret.sh" get xapi-password)"
